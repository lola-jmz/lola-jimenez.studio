# Bot de Telegram "María" - Configuración de Variables de Entorno
# Copia este archivo a .env y completa con tus credenciales reales

# Telegram Bot Token (obtén de @BotFather)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Gemini API Key (obtén de https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your_gemini_api_key_here"

# PostgreSQL Database URL
# Formato: postgresql://usuario:password@host:puerto/nombre_bd
DATABASE_URL="postgresql://maria_bot:your_password@localhost:5432/maria_bot"

# Admin User ID (tu user_id de Telegram)
ADMIN_USER_ID=123456789

# Clave de encriptación (32 bytes en base64)
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="tu_clave_de_encriptacion_aqui"

# Oracle Object Storage (opcional, para Fase 4)
# OCI_NAMESPACE=""
# OCI_BUCKET=""
# OCI_REGION=""
# OCI_ACCESS_KEY_ID=""
# OCI_SECRET_ACCESS_KEY=""

# Configuración del Bot (opcional, valores por defecto)
# MESSAGE_BUFFER_WAIT_SECONDS=3.0
# DB_POOL_MIN_SIZE=10
# DB_POOL_MAX_SIZE=50
# RATE_LIMIT_MESSAGES_PER_MINUTE=20
