# =============================================================================
# Lola Jiménez Studio - Environment Variables Template
# =============================================================================
# Copia este archivo a .env y completa los valores reales
# NUNCA subas el archivo .env a Git (está en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Neon)
# -----------------------------------------------------------------------------
# Connection string de Neon - incluye usuario, password, host, database
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxxx.us-west-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Backblaze B2 (Object Storage)
# -----------------------------------------------------------------------------
# Endpoint S3-compatible de B2 (depende de la región)
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Application Key ID (obtener de Backblaze dashboard)
B2_KEY_ID=your_key_id_here

# Application Key (obtener de Backblaze dashboard - solo se muestra una vez)
B2_APPLICATION_KEY=your_application_key_here

# Nombre del bucket para contenido
B2_BUCKET_NAME=lola-content

# -----------------------------------------------------------------------------
# Gemini AI
# -----------------------------------------------------------------------------
# API key de Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo a usar (opcional, default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Redis (Opcional - para cache)
# -----------------------------------------------------------------------------
# URL de Redis (si usas cache de sesiones/estados)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Aplicación
# -----------------------------------------------------------------------------
# Modo de ejecución: development, staging, production
ENVIRONMENT=development

# Puerto del servidor (Railway asigna $PORT automáticamente)
PORT=8000

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
# Tiempo de expiración de URLs firmadas (en minutos)
URL_EXPIRATION_MINUTES=30

# Secret key para JWT/sessions (generar con: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# -----------------------------------------------------------------------------
# Configuración de Contenido
# -----------------------------------------------------------------------------
# Niveles de producto disponibles (separados por coma)
PRODUCT_LEVELS=feet,lingerie,topless,intimate,lingerie_face,topless_face

# -----------------------------------------------------------------------------
# Telegram Notifier (Opcional)
# -----------------------------------------------------------------------------
# Token del bot de Telegram (obtener de @BotFather)
# Instrucciones:
#   1. Hablar con @BotFather en Telegram
#   2. Enviar /newbot y seguir instrucciones
#   3. Copiar el token que te da
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Chat ID de Guus (para recibir notificaciones)
# Instrucciones:
#   1. Enviar /start a tu bot
#   2. Visitar: https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Buscar "chat":{"id":123456789} en la respuesta
#   4. Copiar el número del ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
